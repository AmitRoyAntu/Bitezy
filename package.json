{
  "name": "bitezy",
  "version": "1.0.0",
  "description": "Bitezy Food Delivery Platform",
  "scripts": {
    "start": "node backend/server.js",
    "frontend": "live-server frontend --port=3002",
    "dev": "concurrently \"npm run frontend\" \"npm run start\"",
    "seed": "node backend/utils/seedData.js",

    "install:backend": "npm install --prefix backend",
    "postinstall": "npm run install:backend"
  },
  "dependencies": {
    "concurrently": "^9.2.1"
  }
}